# Konfigurasi koneksi database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=presensi_db

# URL dasar aplikasi (dipakai untuk membentuk link di dalam QR Code)
# Development:
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production (subpath /presensi di domain u-talent):
NEXT_PUBLIC_BASE_URL=https://u-talent.uika-bogor.ac.id/presensi

# Port untuk menjalankan Next.js (ubah sesuai port yang tersedia di VPS)
PORT=3001
