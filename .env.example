# Konfigurasi koneksi database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=presensi_db

# URL dasar aplikasi (dipakai untuk membentuk link di dalam QR Code)
# Saat development biarkan seperti ini, saat deploy ganti ke domain asli, contoh:
# NEXT_PUBLIC_BASE_URL=https://presensi.namadomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000
