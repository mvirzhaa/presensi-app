# Konfigurasi koneksi database MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=presensi_db

# URL dasar aplikasi (dipakai untuk membentuk link di dalam QR Code)
# Saat development biarkan seperti ini, saat deploy ganti ke domain asli, contoh:
# NEXT_PUBLIC_BASE_URL=https://presensi.namadomain.com
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Subpath tempat aplikasi berjalan (kosongkan jika jalan di root domain)
# Saat development: kosongkan (NEXT_PUBLIC_BASE_PATH=)
# Saat deploy ke subpath /presensi: isi dengan /presensi
NEXT_PUBLIC_BASE_PATH=

# Kredensial login halaman admin (/admin)
# WAJIB diganti sebelum aplikasi dipakai di luar lingkungan development!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Kunci rahasia untuk menandatangani session login admin.
# WAJIB diisi dengan string acak yang panjang & rahasia sebelum production.
# Contoh membuat nilai acak: openssl rand -base64 32
ADMIN_SESSION_SECRET=F3Z5ZAX+fE/Gbp4olmtUS7g7R8QqgedPZe7ye4JsYV0=
